{
  "name": "@vouus/web-i18n",
  "version": "0.1.0",
  "private": false,
  "description": "Canonical English UI copy and locale bundles for Vouus platform surfaces (public repo).",
  "type": "module",
  "scripts": {
    "extract": "node scripts/extract-from-apps.mjs",
    "sync": "node scripts/sync-to-apps.mjs",
    "index": "node scripts/build-keyword-index.mjs",
    "validate": "node scripts/validate.mjs",
    "verify": "npm run validate && npm run index",
    "batch:import-existing": "node scripts/import-existing-locales.mjs",
    "batch:seed-missing": "node scripts/seed-missing-locales.mjs",
    "batch:translate-2": "node scripts/batch-translate-second-pass.mjs",
    "scoped:build-packs": "node scripts/translation-packs/scoped/build-packs.mjs",
    "scoped:apply-si-ur-hi": "node scripts/run-si-ur-hi-translations.mjs",
    "scoped:translate-si-ur-hi": "npm run scoped:build-packs && npm run scoped:apply-si-ur-hi",
    "sea:build": "node scripts/build-locale-data.mjs th id ms",
    "sea:generate": "python3 scripts/translation-packs/generate-sea-data.py",
    "locale:generate": "python3 scripts/generate-locale-data.py",
    "locale:build": "node scripts/build-locale-data.mjs",
    "patch:www-home-shell": "node scripts/patch-www-home-shell-complete.mjs",
    "mark:reviewed": "node scripts/mark-reviewed.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
